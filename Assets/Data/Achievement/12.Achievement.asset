  JADesc: "\u6570\u5B57\u306F\u6B8B\u9177\u3060\u3002\u7D50\u679C\u306F\u660E\u767D\u3060\u3063\u305F\u3002"
  PT_BRTitle: "Vit\xF3ria Avassaladora"
  PT_BRDesc: "Os n\xFAmeros s\xE3o implac\xE1veis. O resultado era evidente."
