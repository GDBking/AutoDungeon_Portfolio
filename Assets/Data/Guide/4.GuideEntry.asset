  m_Script: {fileID: 11500000, guid: 96efabfa0d413f340b7e4b049eea0558, type: 3}
  m_Name: 4.GuideEntry
  m_EditorClassIdentifier: 
  Title: "\uC0C1\uD0DC\uC774\uC0C1"
  Desc: "<b>\uD654\uC0C1</b>: \uCCB4\uB825 \uD68C\uBCF5\uB7C9 40% \uAC10\uC18C, \uACF5\uACA9\uB825
    10% \uAC10\uC18C\r\n\r\n<b>\uC18D\uBC15</b>: \uC774\uB3D9 \uBD88\uAC00, \uC774\uB3D9
    \uC678\uC5D0 \uC0AC\uC815 \uAC70\uB9AC \uB0B4\uC5D0 \uACF5\uACA9 \uB610\uB294
    \uC2A4\uD0AC \uC0AC\uC6A9 \uB4F1\uC740 \uAC00\uB2A5\r\n\r\n<b>\uAE30\uC808</b>:
    \uC774\uB3D9, \uACF5\uACA9, \uC2A4\uD0AC \uC0AC\uC6A9 \uB4F1 \uBD88\uAC00\r\n\r\n<b>\uB3C5</b>:
    \uACF5\uACA9 \uC18D\uB3C4 25% \uAC10\uC18C\r\n\r\n<b>\uCE68\uBB35</b>: \uB9C8\uB098
    \uCDA9\uC804, \uC2A4\uD0AC \uC0AC\uC6A9 \uBD88\uAC00\r\n\r\n<b>\uCD9C\uD608</b>:
    \uACF5\uACA9\uB825, \uBC29\uC5B4\uB825 15% \uAC10\uC18C\r\n\r\n<b>\uB3C4\uBC1C</b>:
    \uC801\uC758 \uACF5\uACA9 \uD0C0\uAC9F\uC774 \uBCF8\uC778\uC774 \uB418\uB3C4\uB85D
    \uD568\r\n\r\n<b>\uCE58\uC720 \uBC29\uD574</b>: \uCCB4\uB825 \uD68C\uBCF5 \uBD88\uAC00\r\n\r\n<b>\uB9E4\uD639</b>:
    \uACF5\uACA9 \uBD88\uAC00\r\n\r\n<b>\uAD11\uB780</b>: \uC544\uAD70 \uC720\uB2DB\uC744
    \uACF5\uACA9(\uC2A4\uD0AC\uC740 \uC0AC\uC6A9\uD558\uC9C0 \uC54A\uC74C)"
  ENTitle: 
  ENDesc: '<b>Burn</b>: Healing received reduced by 40%, attack reduced by 10%


    <b>Bind</b>:
    Cannot move; attacks or skill use within range (excluding movement) are still
    possible


    <b>Stun</b>: Cannot move, attack, or use skills


    <b>Poison</b>:
    Attack speed reduced by 25%


    <b>Silence</b>: Mana charging and skill use
    disabled


    <b>Bleed</b>: Attack and defense reduced by 15%


    <b>Taunt</b>:
    Forces enemies to target this unit with attacks


    <b>Healing Block</b>: Healing
    disabled


    <b>Charm</b>: Cannot attack


    <b>Frenzy</b>: Attacks allied
    units (skills are not used)'
  FRTitle: 
  FRDesc: "<b>Br\xFBlure</b> : Soins re\xE7us r\xE9duits de 40 %, attaque r\xE9duite
    de 10 %\n\n<b>Entrave</b> : Impossible de se d\xE9placer ; attaques ou comp\xE9tences
    dans la port\xE9e restent possibles\n\n<b>\xC9tourdissement</b> : Impossible
    de se d\xE9placer, d\u2019attaquer ou d\u2019utiliser des comp\xE9tences\n\n<b>Poison</b>
    : Vitesse d\u2019attaque r\xE9duite de 25 %\n\n<b>Silence</b> : Recharge de mana
    et utilisation de comp\xE9tences d\xE9sactiv\xE9es\n\n<b>Saignement</b> : Attaque
    et d\xE9fense r\xE9duites de 15 %\n\n<b>Provocation</b> : Force les ennemis \xE0
    cibler cette unit\xE9\n\n<b>Blocage de soin</b> : Soins impossibles\n\n<b>Envo\xFBtement</b>
    : Impossible d\u2019attaquer\n\n<b>Fr\xE9n\xE9sie</b> : Attaque les unit\xE9s
    alli\xE9es (n\u2019utilise pas de comp\xE9tences)"
  ITTitle: 
  ITDesc: "<b>Ustione</b>: Cure ricevute ridotte del 40%, attacco ridotto del 10%\n\n<b>Legame</b>:
    Impossibile muoversi; attacchi o uso di abilit\xE0 a portata sono comunque possibili\n\n<b>Stordimento</b>:
    Impossibile muoversi, attaccare o usare abilit\xE0\n\n<b>Veleno</b>: Velocit\xE0
    d\u2019attacco ridotta del 25%\n\n<b>Silenzio</b>: Ricarica del mana e uso delle
    abilit\xE0 disabilitati\n\n<b>Sanguinamento</b>: Attacco e difesa ridotti del
    15%\n\n<b>Provocazione</b>: Costringe i nemici a prendere di mira questa unit\xE0\n\n<b>Blocca
    cura</b>: Impossibilit\xE0 di curarsi\n\n<b>Fascinazione</b>: Impossibile attaccare\n\n<b>Frenesia</b>:
    Attacca unit\xE0 alleate (non usa abilit\xE0)"
  DETitle: 
  DEDesc: "<b>Brand</b>: Erhaltene Heilung um 40 % reduziert, Angriff um 10 % reduziert\n\n<b>Fessel</b>:
    Bewegung nicht m\xF6glich; Angriffe oder F\xE4higkeiten innerhalb der Reichweite
    sind weiterhin m\xF6glich\n\n<b>Bet\xE4ubung</b>: Keine Bewegung, kein Angriff,
    keine F\xE4higkeitennutzung m\xF6glich\n\n<b>Gift</b>: Angriffsgeschwindigkeit
    um 25 % reduziert\n\n<b>Stille</b>: Manaaufladung und F\xE4higkeitsnutzung deaktiviert\n\n<b>Blutung</b>:
    Angriff und Verteidigung um 15 % reduziert\n\n<b>Spott</b>: Zwingt Feinde dazu,
    diese Einheit als Ziel zu w\xE4hlen\n\n<b>Heilungsblock</b>: Heilung nicht m\xF6glich\n\n<b>Bezauberung</b>:
    Angriff nicht m\xF6glich\n\n<b>Raserei</b>: Greift verb\xFCndete Einheiten an
    (keine F\xE4higkeiten)"
  ESTitle: 
  ESDesc: "<b>Quemadura</b>: Curaci\xF3n recibida reducida en 40 %, ataque reducido
    en 10 %\n\n<b>Atadura</b>: No puede moverse; los ataques o habilidades dentro
    del alcance (excluyendo movimiento) siguen siendo posibles\n\n<b>Aturdimiento</b>:
    No puede moverse, atacar ni usar habilidades\n\n<b>Veneno</b>: Velocidad de ataque
    reducida en 25 %\n\n<b>Silencio</b>: Carga de man\xE1 y uso de habilidades deshabilitados\n\n<b>Sangrado</b>:
    Ataque y defensa reducidos en 15 %\n\n<b>Provocaci\xF3n</b>: Obliga a los enemigos
    a atacar a esta unidad\n\n<b>Bloqueo de curaci\xF3n</b>: La curaci\xF3n est\xE1
    deshabilitada\n\n<b>Fascinaci\xF3n</b>: No puede atacar\n\n<b>Frenes\xED</b>:
    Ataca a unidades aliadas (no usa habilidades)"
  JATitle: 
  JADesc: "<b>\u71C3\u713C</b>: \u56DE\u5FA9\u91CF\u304C40%\u6E1B\u5C11\u3001\u653B\u6483\u529B\u304C10%\u6E1B\u5C11\n\n<b>\u62D8\u675F</b>:
    \u79FB\u52D5\u4E0D\u53EF\u3002\u79FB\u52D5\u4EE5\u5916\u306E\u5C04\u7A0B\u5185\u3067\u306E\u653B\u6483\u3084\u30B9\u30AD\u30EB\u4F7F\u7528\u306F\u53EF\u80FD\n\n<b>\u6C17\u7D76</b>:
    \u79FB\u52D5\u30FB\u653B\u6483\u30FB\u30B9\u30AD\u30EB\u4F7F\u7528\u4E0D\u53EF\n\n<b>\u6BD2</b>:
    \u653B\u6483\u901F\u5EA6\u304C25%\u4F4E\u4E0B\n\n<b>\u6C88\u9ED9</b>: \u30DE\u30CA\u30C1\u30E3\u30FC\u30B8\u304A\u3088\u3073\u30B9\u30AD\u30EB\u4F7F\u7528\u4E0D\u53EF\n\n<b>\u51FA\u8840</b>:
    \u653B\u6483\u529B\u30FB\u9632\u5FA1\u529B\u304C15%\u6E1B\u5C11\n\n<b>\u6311\u767A</b>:
    \u6575\u306E\u653B\u6483\u30BF\u30FC\u30B2\u30C3\u30C8\u304C\u3053\u306E\u30E6\u30CB\u30C3\u30C8\u306B\u306A\u308A\u307E\u3059\n\n<b>\u6CBB\u7652\u59A8\u5BB3</b>:
    \u56DE\u5FA9\u4E0D\u53EF\n\n<b>\u9B45\u4E86</b>: \u653B\u6483\u4E0D\u53EF\n\n<b>\u72C2\u4E71</b>:
    \u5473\u65B9\u30E6\u30CB\u30C3\u30C8\u3092\u653B\u6483\uFF08\u30B9\u30AD\u30EB\u306F\u4F7F\u7528\u3057\u306A\u3044\uFF09"
  PT_BRTitle: 
  PT_BRDesc: "<b>Queimadura</b>: Cura recebida reduzida em 40%, ataque reduzido em
    10%\n\n<b>Vincula\xE7\xE3o</b>: N\xE3o \xE9 poss\xEDvel mover; ataques ou uso
    de habilidades dentro do alcance ainda s\xE3o poss\xEDveis\n\n<b>Atordoamento</b>:
    N\xE3o \xE9 poss\xEDvel mover, atacar ou usar habilidades\n\n<b>Veneno</b>: Velocidade
    de ataque reduzida em 25%\n\n<b>Sil\xEAncio</b>: Carregamento de mana e uso de
    habilidades desativados\n\n<b>Sangramento</b>: Ataque e defesa reduzidos em 15%\n\n<b>Provoca\xE7\xE3o</b>:
    Obriga inimigos a mirar esta unidade com ataques\n\n<b>Bloqueio de cura</b>:
    Cura desativada\n\n<b>Fascina\xE7\xE3o</b>: Incapaz de atacar\n\n<b>Frenesi</b>:
    Ataca unidades aliadas (n\xE3o usa habilidades)"
  RUTitle: 
  RUDesc: "<b>\u0413\u043E\u0440\u0435\u043D\u0438\u0435</b>: \u0412\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435
    \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F \u0443\u043C\u0435\u043D\u044C\u0448\u0435\u043D\u043E
    \u043D\u0430 40%, \u0430\u0442\u0430\u043A\u0430 \u0443\u043C\u0435\u043D\u044C\u0448\u0435\u043D\u0430
    \u043D\u0430 10%\n\n<b>\u0421\u0432\u044F\u0437\u043A\u0430</b>: \u041D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E
    \u0434\u0432\u0438\u0433\u0430\u0442\u044C\u0441\u044F; \u0430\u0442\u0430\u043A\u0438
    \u0438\u043B\u0438 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0443\u043C\u0435\u043D\u0438\u0439 \u0432 \u043F\u0440\u0435\u0434\u0435\u043B\u0430\u0445
    \u0434\u043E\u0441\u044F\u0433\u0430\u0435\u043C\u043E\u0441\u0442\u0438 \u043F\u043E-\u043F\u0440\u0435\u0436\u043D\u0435\u043C\u0443
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\n\n<b>\u041E\u0433\u043B\u0443\u0448\u0435\u043D\u0438\u0435</b>:
    \u041D\u0435\u043B\u044C\u0437\u044F \u0434\u0432\u0438\u0433\u0430\u0442\u044C\u0441\u044F,
    \u0430\u0442\u0430\u043A\u043E\u0432\u0430\u0442\u044C \u0438\u043B\u0438 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
    \u0443\u043C\u0435\u043D\u0438\u044F\n\n<b>\u042F\u0434</b>: \u0421\u043A\u043E\u0440\u043E\u0441\u0442\u044C
    \u0430\u0442\u0430\u043A\u0438 \u0443\u043C\u0435\u043D\u044C\u0448\u0435\u043D\u0430
    \u043D\u0430 25%\n\n<b>\u0411\u0435\u0437\u043C\u043E\u043B\u0432\u0438\u0435</b>:
    \u0417\u0430\u0440\u044F\u0434 \u043C\u0430\u043D\u044B \u0438 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0443\u043C\u0435\u043D\u0438\u0439 \u043E\u0442\u043A\u043B\u044E\u0447\u0435\u043D\u044B\n\n<b>\u041A\u0440\u043E\u0432\u043E\u0442\u0435\u0447\u0435\u043D\u0438\u0435</b>:
    \u0410\u0442\u0430\u043A\u0430 \u0438 \u0437\u0430\u0449\u0438\u0442\u0430 \u0443\u043C\u0435\u043D\u044C\u0448\u0435\u043D\u044B
    \u043D\u0430 15%\n\n<b>\u0414\u0440\u0430\u0437\u043D\u0435\u043D\u0438\u0435</b>:
    \u0417\u0430\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442 \u0432\u0440\u0430\u0433\u043E\u0432
    \u0432\u044B\u0431\u0438\u0440\u0430\u0442\u044C \u044D\u0442\u0443 \u0435\u0434\u0438\u043D\u0438\u0446\u0443
    \u0446\u0435\u043B\u044C\u044E \u0434\u043B\u044F \u0430\u0442\u0430\u043A\n\n<b>\u0411\u043B\u043E\u043A
    \u043B\u0435\u0447\u0435\u043D\u0438\u044F</b>: \u0412\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435
    \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F \u043E\u0442\u043A\u043B\u044E\u0447\u0435\u043D\u043E\n\n<b>\u041E\u0447\u0430\u0440\u043E\u0432\u0430\u043D\u0438\u0435</b>:
    \u041D\u0435\u043B\u044C\u0437\u044F \u0430\u0442\u0430\u043A\u043E\u0432\u0430\u0442\u044C\n\n<b>\u0411\u0435\u0437\u0443\u043C\u0438\u0435</b>:
    \u0410\u0442\u0430\u043A\u0443\u0435\u0442 \u0441\u043E\u044E\u0437\u043D\u044B\u0435
    \u044E\u043D\u0438\u0442\u044B (\u0443\u043C\u0435\u043D\u0438\u044F \u043D\u0435
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0442\u0441\u044F)"
  ZH_HANSTitle: 
  ZH_HANSDesc: "<b>\u707C\u70E7</b>\uFF1A\u6062\u590D\u91CF\u51CF\u5C1140%\uFF0C\u653B\u51FB\u529B\u51CF\u5C1110%\n\n<b>\u675F\u7F1A</b>\uFF1A\u65E0\u6CD5\u79FB\u52A8\uFF1B\u9664\u79FB\u52A8\u5916\uFF0C\u5C04\u7A0B\u5185\u7684\u653B\u51FB\u6216\u6280\u80FD\u4F7F\u7528\u4ECD\u53EF\u8FDB\u884C\n\n<b>\u7729\u6655</b>\uFF1A\u65E0\u6CD5\u79FB\u52A8\u3001\u653B\u51FB\u6216\u4F7F\u7528\u6280\u80FD\n\n<b>\u4E2D\u6BD2</b>\uFF1A\u653B\u51FB\u901F\u5EA6\u51CF\u5C1125%\n\n<b>\u6C89\u9ED8</b>\uFF1A\u6CD5\u529B\u5145\u80FD\u4E0E\u6280\u80FD\u4F7F\u7528\u88AB\u7981\u7528\n\n<b>\u6D41\u8840</b>\uFF1A\u653B\u51FB\u4E0E\u9632\u5FA1\u51CF\u5C1115%\n\n<b>\u5632\u8BBD</b>\uFF1A\u4F7F\u654C\u4EBA\u5C06\u653B\u51FB\u76EE\u6807\u6307\u5411\u8BE5\u5355\u4F4D\n\n<b>\u6CBB\u7597\u963B\u65AD</b>\uFF1A\u65E0\u6CD5\u88AB\u6CBB\u7597\n\n<b>\u9B45\u60D1</b>\uFF1A\u65E0\u6CD5\u653B\u51FB\n\n<b>\u72C2\u4E71</b>\uFF1A\u653B\u51FB\u53CB\u65B9\u5355\u4F4D\uFF08\u4E0D\u4F7F\u7528\u6280\u80FD\uFF09"
