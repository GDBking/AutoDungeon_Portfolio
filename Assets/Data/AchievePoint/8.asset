  JATitle: "\u9650\u754C\u7A81\u7834"
  JADesc: "\u30E6\u30CB\u30C3\u30C8\u306E\u6B20\u7247\u3092\u5F37\u5316\u3059\u308B\u969B\u3001\u5F37\u5316\u6E08\u307F\u306E2\u30C6\u30A3\u30A2\u30B9\u30ED\u30C3\u30C8\u304C\u51FA\u73FE\u3059\u308B\u3053\u3068\u304C\u3042\u308A\u307E\u3059\u3002"
  PT_BRTitle: Quebra de Limite
  PT_BRDesc: "Ao aprimorar Fragmentos de unidade, h\xE1 uma chance de surgir um slot
    aprimorado de Tier 2."
  RUTitle: "\u041F\u0440\u043E\u0440\u044B\u0432 \u043F\u0440\u0435\u0434\u0435\u043B\u0430"
  RUDesc: "\u041F\u0440\u0438 \u0443\u043B\u0443\u0447\u0448\u0435\u043D\u0438\u0438
    \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442\u043E\u0432 \u044E\u043D\u0438\u0442\u0430
    \u0435\u0441\u0442\u044C \u0448\u0430\u043D\u0441 \u043F\u043E\u044F\u0432\u043B\u0435\u043D\u0438\u044F
    \u0443\u0441\u0438\u043B\u0435\u043D\u043D\u043E\u0433\u043E \u0441\u043B\u043E\u0442\u0430
    2-\u0433\u043E \u0443\u0440\u043E\u0432\u043D\u044F."
  ZH_HANSTitle: "\u7A81\u7834\u6781\u9650"
  ZH_HANSDesc: "\u5347\u7EA7\u5355\u4F4D\u788E\u7247\u65F6\uFF0C\u6709\u6982\u7387\u51FA\u73B0\u5F3A\u5316\u76842\u9636\u69FD\u4F4D\u3002"
