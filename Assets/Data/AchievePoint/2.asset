  JATitle: "\u6B20\u7247\u7CBE\u932C II"
  JADesc: "\u5F37\u5316\u77F3\u3092\u4F7F\u3063\u3066\u30A2\u30A4\u30C6\u30E0\u306E\u6B20\u7247\u3092\u30EC\u30D9\u30EB2\u307E\u3067\u30A2\u30C3\u30D7\u30B0\u30EC\u30FC\u30C9\u3067\u304D\u308B\u3088\u3046\u306B\u306A\u308A\u307E\u3059\u3002"
  PT_BRTitle: Refino de Fragmentos II
  PT_BRDesc: "Permite aprimorar Fragmentos de item at\xE9 o n\xEDvel 2 usando Pedras
    de Aprimoramento."
  RUTitle: "\u041E\u0447\u0438\u0441\u0442\u043A\u0430 \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442\u043E\u0432
