  m_TableData:
  - m_Id: 146277892096
    m_Localized: "\u0417\u0434\u0435\u0441\u044C \u043F\u043E\u043A\u043E\u0438\u0442\u0441\u044F
      \u0434\u0432\u0435\u0440\u044C \u043D\u043E\u0432\u043E\u0433\u043E \u043D\u0430\u0447\u0430\u043B\u0430.
      \u041D\u0430\u0436\u043C\u0438\u0442\u0435 \u043D\u0430 \u0437\u043D\u0430\u0447\u043E\u043A
      \u043D\u0438\u0436\u0435, \u0447\u0442\u043E\u0431\u044B \u043F\u0440\u043E\u0431\u0443\u0434\u0438\u0442\u044C
      \u0435\u0451."
    m_Metadata:
      m_Items: []
  - m_Id: 13598681694208
    m_Localized: "\u041E\u0442\u043A\u0440\u043E\u0439\u0442\u0435 \u043A\u043E\u043B\u043E\u0434\u0443,
      \u0447\u0442\u043E\u0431\u044B \u043F\u0440\u043E\u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C
      \u0438\u043C\u0435\u044E\u0449\u0438\u0435\u0441\u044F \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442\u044B."
    m_Metadata:
      m_Items: []
  - m_Id: 29235755843584
    m_Localized: "\u0421\u043D\u043E\u0432\u0430 \u043D\u0430\u0436\u043C\u0438\u0442\u0435
      \u043D\u0430 \u043A\u043E\u043B\u043E\u0434\u0443, \u0447\u0442\u043E\u0431\u044B
      \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C \u0442\u0435\u043A\u0443\u0449\u0438\u0439
      \u0441\u043E\u0441\u0442\u0430\u0432."
    m_Metadata:
      m_Items: []
  - m_Id: 29401237913600
    m_Localized: "\u041D\u0430\u0432\u0435\u0434\u0438\u0442\u0435 \u043A\u0443\u0440\u0441\u043E\u0440
      \u043D\u0430 \u044E\u043D\u0438\u0442\u0430, \u0447\u0442\u043E\u0431\u044B
      \u0443\u0432\u0438\u0434\u0435\u0442\u044C \u0435\u0433\u043E \u0442\u0438\u0442\u0443\u043B
      \u0432 \u043B\u0435\u0432\u043E\u043C \u043E\u043A\u043D\u0435 \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u044F.\\n\u0422\u0430\u043A\u0436\u0435
      \u043C\u043E\u0436\u043D\u043E \u0443\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0442\u044C
      \u043A\u043B\u0430\u0432\u0438\u0448\u0443 Shift."
    m_Metadata:
      m_Items: []
  - m_Id: 29687717265408
    m_Localized: "\u0421\u043D\u043E\u0432\u0430 \u043D\u0430\u0436\u043C\u0438\u0442\u0435
      \u043D\u0430 \u043A\u043E\u043B\u043E\u0434\u0443, \u0447\u0442\u043E\u0431\u044B
      \u0437\u0430\u043A\u0440\u044B\u0442\u044C \u0435\u0451."
    m_Metadata:
      m_Items: []
  - m_Id: 29886749573120
    m_Localized: "\u0420\u0435\u043B\u0438\u043A\u0432\u0438\u044F \u0432 \u0432\u0435\u0440\u0445\u043D\u0435\u0439
      \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0439 \u0447\u0430\u0441\u0442\u0438
      \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442 \u0442\u0438\u0442\u0443\u043B,
      \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E \u043F\u0440\u0438\u0441\u0432\u0430\u0438\u0432\u0430\u0435\u043C\u044B\u0439
      \u043A\u0430\u0436\u0434\u043E\u043C\u0443 \u044E\u043D\u0438\u0442\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 29890876768256
    m_Localized: "\u041D\u0430\u0436\u043C\u0438\u0442\u0435 \u043A\u043D\u043E\u043F\u043A\u0443
      \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F \u0431\u0430\u0437\u043E\u0432\u043E\u0433\u043E
      \u044E\u043D\u0438\u0442\u0430, \u0447\u0442\u043E\u0431\u044B \u043F\u0440\u0438\u0437\u0432\u0430\u0442\u044C
      \u0431\u0430\u0437\u043E\u0432\u043E\u0433\u043E \u044E\u043D\u0438\u0442\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 32836146397184
    m_Localized: "\u041F\u0435\u0440\u0435\u0442\u0430\u0449\u0438\u0442\u0435 \u044E\u043D\u0438\u0442\u0430
      \u0438\u0437 \u0440\u0443\u043A\u0438 \u043D\u0430 \u0431\u0430\u0437\u043E\u0432\u043E\u0433\u043E
      \u044E\u043D\u0438\u0442\u0430 \u043D\u0430 \u043F\u043E\u043B\u0435, \u0447\u0442\u043E\u0431\u044B
      \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u0442\u044C
      \u0435\u0433\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 685354316693504
    m_Localized: "\u041C\u0430\u043B\u044B\u0435 \u0440\u0435\u0448\u0435\u043D\u0438\u044F
      \u0441\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u044E\u0442\u0441\u044F \u0432
      \u0442\u0430\u043A\u0442\u0438\u043A\u0443. \u041D\u0435 \u0441\u043F\u0435\u0448\u0438\u0442\u0435
      \u0438 \u0432\u044B\u0431\u0438\u0440\u0430\u0439\u0442\u0435 \u0441\u0430\u043C\u044B\u0439
      \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0439 \u043F\u0443\u0442\u044C.
      \u0423\u0434\u0430\u0447\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 29889668808704
    m_Localized: "\u0420\u0435\u043B\u0438\u043A\u0432\u0438\u0438 \u0432 \u043B\u0435\u0432\u043E\u043C
      \u043D\u0438\u0436\u043D\u0435\u043C \u0443\u0433\u043B\u0443 \u0430\u043A\u0442\u0438\u0432\u043D\u044B.\\n\u0410\u043A\u0442\u0438\u0432\u043D\u044B\u0435
      \u0440\u0435\u043B\u0438\u043A\u0432\u0438\u0438 \u043D\u0430\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u044E\u0442
      \u0431\u0430\u0444\u0444\u044B \u0438\u043B\u0438 \u0434\u0435\u0431\u0430\u0444\u0444\u044B
      \u043D\u0430 \u0432\u0441\u0435\u0445 \u0441\u043E\u044E\u0437\u043D\u044B\u0445
      \u044E\u043D\u0438\u0442\u043E\u0432 \u0432 \u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E\u0441\u0442\u0438
      \u043E\u0442 \u0442\u0438\u0442\u0443\u043B\u043E\u0432."
    m_Metadata:
      m_Items: []
  - m_Id: 314232547016704
    m_Localized: "\u0411\u043E\u0438 \u0438\u043C\u0435\u044E\u0442 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0435\u043D\u0438\u0435
      \u043F\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438.\\n\u041F\u0440\u0438
      \u0433\u0438\u0431\u0435\u043B\u0438 \u044E\u043D\u0438\u0442\u0430 \u0435\u0433\u043E
      \u0441\u0442\u043E\u0438\u043C\u043E\u0441\u0442\u044C \u043F\u0440\u0435\u0432\u0440\u0430\u0449\u0430\u0435\u0442\u0441\u044F
      \u0432 \u043E\u0447\u043A\u0438 \u0434\u043B\u044F \u043F\u0440\u043E\u0442\u0438\u0432\u043D\u0438\u043A\u0430.\\n\u041F\u043E\u0431\u0435\u0436\u0434\u0430\u0435\u0442
      \u0442\u043E\u0442, \u0443 \u043A\u043E\u0433\u043E \u0431\u043E\u043B\u044C\u0448\u0435
      \u043E\u0447\u043A\u043E\u0432 \u043F\u043E \u0438\u0441\u0442\u0435\u0447\u0435\u043D\u0438\u0438
      \u0432\u0440\u0435\u043C\u0435\u043D\u0438."
    m_Metadata:
      m_Items: []
