  m_TableData:
  - m_Id: 146277892096
    m_Localized: "\uC0C8\uB85C\uC6B4 \uC2DC\uC791\uC758 \uBB38\uC774 \uC5EC\uAE30
      \uC7A0\uB4E4\uC5B4 \uC788\uC2B5\uB2C8\uB2E4. \uC544\uB798 \uC544\uC774\uCF58\uC744
      \uB20C\uB7EC \uAE68\uC6CC\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 13598681694208
    m_Localized: "\uB371\uC744 \uB20C\uB7EC \uBCF4\uC720\uD55C \uC870\uAC01\uC744
      \uD3BC\uCCD0\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 29235755843584
    m_Localized: "\uB2E4\uC2DC \uB371\uC744 \uB20C\uB7EC \uD604\uC7AC \uB371 \uAD6C\uC131\uC744
      \uD655\uC778\uD558\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 29401237913600
    m_Localized: "\uB9C8\uC6B0\uC2A4\uB97C \uC720\uB2DB \uC704\uC5D0 \uC62C\uB9AC\uBA74
      \uC67C\uCABD \uC0C1\uD0DC\uCC3D\uC5D0\uC11C \uCE6D\uD638\uB97C \uD655\uC778\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4.\\n\uB610\uB294 Shift \uD0A4\uB97C \uB20C\uB7EC\uC11C\uB3C4
      \uD655\uC778\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 29687717265408
    m_Localized: "\uB2E4\uC2DC \uB371\uC744 \uB20C\uB7EC \uB371\uC744 \uB2EB\uC544\uBCF4\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 29886749573120
    m_Localized: "\uC911\uC559 \uC0C1\uB2E8\uC758 \uC720\uBB3C\uC740 \uAC01 \uC720\uB2DB\uC5D0\uAC8C
      \uB79C\uB364\uC73C\uB85C \uBD80\uC5EC\uB418\uB294 \uCE6D\uD638\uB97C \uB098\uD0C0\uB0C5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 29889668808704
    m_Localized: "\uC67C\uCABD \uD558\uB2E8\uC758 \uC720\uBB3C\uB4E4\uC740 \uD604\uC7AC
      \uD65C\uC131\uD654\uB41C \uC720\uBB3C\uC785\uB2C8\uB2E4.\\n\uD65C\uC131\uD654\uB41C
      \uC720\uBB3C\uC740 \uC720\uB2DB\uC758 \uCE6D\uD638\uC5D0 \uB530\uB77C \uC544\uAD70
      \uC720\uB2DB \uC804\uCCB4\uC5D0 \uBC84\uD504 \uB610\uB294 \uB514\uBC84\uD504\uB97C
      \uBD80\uC5EC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 29890876768256
    m_Localized: "\uAE30\uBCF8 \uC720\uB2DB \uC0DD\uC131 \uBC84\uD2BC\uC744 \uB20C\uB7EC
      \uAE30\uBCF8 \uC720\uB2DB\uC744 \uC18C\uD658\uD558\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 32836146397184
    m_Localized: "\uD328\uC5D0 \uC788\uB294 \uC720\uB2DB\uC744 \uB4DC\uB798\uADF8\uD558\uC5EC
      \uD544\uB4DC\uC758 \uAE30\uBCF8 \uC720\uB2DB \uC704\uC5D0 \uB193\uC73C\uBA74
      \uD574\uB2F9 \uC720\uB2DB\uC73C\uB85C \uBCC0\uD658\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 314232547016704
    m_Localized: "\uC804\uD22C\uC5D0\uB294 \uC81C\uD55C \uC2DC\uAC04\uC774 \uC788\uC2B5\uB2C8\uB2E4.\\n\uC720\uB2DB\uC774
      \uC0AC\uB9DD\uD558\uBA74 \uD574\uB2F9 \uC720\uB2DB\uC758 \uCF54\uC2A4\uD2B8\uAC00
      \uC0C1\uB300\uC758 \uC810\uC218\uB85C \uC804\uD658\uB429\uB2C8\uB2E4.\\n\uC2DC\uAC04\uC774
      \uC885\uB8CC\uB418\uC5C8\uC744 \uB54C \uB354 \uB9CE\uC740 \uC810\uC218\uB97C
      \uD68D\uB4DD\uD55C \uCABD\uC774 \uC2B9\uB9AC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 685354316693504
    m_Localized: "\uC791\uC740 \uC120\uD0DD\uB4E4\uC774 \uBAA8\uC5EC \uC804\uC220\uC774
      \uB429\uB2C8\uB2E4. \uCC9C\uCC9C\uD788 \uC0B4\uD53C\uACE0 \uAC00\uC7A5 \uD569\uB9AC\uC801\uC778
      \uAE38\uC744 \uD0DD\uD558\uC138\uC694. \uADF8\uB7FC \uD589\uC6B4\uC744 \uBE55\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
