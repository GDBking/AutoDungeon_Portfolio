  m_SharedData: {fileID: 11400000, guid: 694b66005ccac71409114fe8cae9ef70, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 146277892096
    m_Localized: "La porte d\u2019un nouveau d\xE9part sommeille ici. Appuyez sur
      l\u2019ic\xF4ne ci-dessous pour l\u2019\xE9veiller."
    m_Metadata:
      m_Items: []
  - m_Id: 13598681694208
    m_Localized: "Ouvrez le deck pour afficher les fragments que vous poss\xE9dez."
    m_Metadata:
      m_Items: []
  - m_Id: 29235755843584
    m_Localized: "Appuyez \xE0 nouveau sur le deck pour v\xE9rifier sa composition
      actuelle."
    m_Metadata:
      m_Items: []
  - m_Id: 29401237913600
    m_Localized: "Placez le curseur sur une unit\xE9 pour voir son titre dans le
      panneau de statut \xE0 gauche.\\nVous pouvez \xE9galement maintenir la touche
      Shift."
    m_Metadata:
      m_Items: []
  - m_Id: 29687717265408
    m_Localized: "Appuyez \xE0 nouveau sur le deck pour le fermer."
    m_Metadata:
      m_Items: []
  - m_Id: 29886749573120
    m_Localized: "La relique en haut au centre repr\xE9sente un titre attribu\xE9
      al\xE9atoirement \xE0 chaque unit\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 29890876768256
    m_Localized: "Appuyez sur le bouton de cr\xE9ation d\u2019unit\xE9 de base pour
      invoquer une unit\xE9 de base."
    m_Metadata:
      m_Items: []
  - m_Id: 32836146397184
    m_Localized: "Faites glisser une unit\xE9 de votre main sur une unit\xE9 de base
      sur le terrain pour la transformer."
    m_Metadata:
      m_Items: []
  - m_Id: 685354316693504
    m_Localized: "De petits choix forment une strat\xE9gie. Prenez le temps d\u2019observer
      et choisissez la voie la plus raisonnable. Bonne chance."
    m_Metadata:
      m_Items: []
  - m_Id: 29889668808704
    m_Localized: "Les reliques en bas \xE0 gauche sont actuellement actives.\\nElles
      conf\xE8rent des bonus ou malus \xE0 toutes les unit\xE9s alli\xE9es selon
      leurs titres."
    m_Metadata:
      m_Items: []
  - m_Id: 314232547016704
    m_Localized: "Les combats ont une limite de temps.\\nLorsqu\u2019une unit\xE9
      meurt, son co\xFBt est converti en points pour l\u2019adversaire.\\nLe joueur
      ayant le plus de points \xE0 la fin du temps imparti gagne."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
