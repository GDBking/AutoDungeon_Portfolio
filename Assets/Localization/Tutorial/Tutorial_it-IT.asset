  m_Name: Tutorial_it-IT
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: it-IT
  m_SharedData: {fileID: 11400000, guid: 694b66005ccac71409114fe8cae9ef70, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 146277892096
    m_Localized: "La porta di un nuovo inizio riposa qui. Premi l\u2019icona qui
      sotto per risvegliarla."
    m_Metadata:
      m_Items: []
  - m_Id: 13598681694208
    m_Localized: Apri il mazzo per visualizzare i frammenti in tuo possesso.
    m_Metadata:
      m_Items: []
  - m_Id: 29235755843584
    m_Localized: Premi di nuovo il mazzo per controllarne la composizione attuale.
    m_Metadata:
      m_Items: []
  - m_Id: 29401237913600
    m_Localized: "Passa il mouse sopra un\u2019unit\xE0 per visualizzare il titolo
      nel pannello di stato a sinistra.\\nPuoi anche tenere premuto Shift."
    m_Metadata:
      m_Items: []
  - m_Id: 29687717265408
    m_Localized: Premi di nuovo il mazzo per chiuderlo.
    m_Metadata:
      m_Items: []
  - m_Id: 29886749573120
    m_Localized: "La reliquia in alto al centro rappresenta un titolo assegnato casualmente
      a ogni unit\xE0."
    m_Metadata:
      m_Items: []
  - m_Id: 29890876768256
    m_Localized: "Premi il pulsante di creazione dell\u2019unit\xE0 base per evocare
      un\u2019unit\xE0 base."
    m_Metadata:
      m_Items: []
  - m_Id: 32836146397184
    m_Localized: "Trascina un\u2019unit\xE0 dalla mano e posizionala su un\u2019unit\xE0
      base sul campo per trasformarla."
    m_Metadata:
      m_Items: []
  - m_Id: 685354316693504
    m_Localized: "Le piccole scelte creano la strategia. Osserva con calma e scegli
      il percorso pi\xF9 razionale. Buona fortuna."
    m_Metadata:
      m_Items: []
  - m_Id: 29889668808704
    m_Localized: "Le reliquie in basso a sinistra sono attualmente attive.\\nLe reliquie
      attive conferiscono bonus o penalit\xE0 a tutte le unit\xE0 alleate in base
      ai titoli."
    m_Metadata:
      m_Items: []
  - m_Id: 314232547016704
    m_Localized: "Le battaglie hanno un limite di tempo.\\nQuando un\u2019unit\xE0
      muore, il suo costo viene convertito in punti per l\u2019avversario.\\nVince
      chi ha pi\xF9 punti allo scadere del tempo."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
