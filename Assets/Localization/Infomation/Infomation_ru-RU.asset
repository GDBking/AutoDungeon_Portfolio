  m_TableData:
  - m_Id: 6217498624
    m_Localized: "\u0420\u0435\u043B\u0438\u043A\u0432\u0438\u044F \u0441\u043E\u044E\u0437\u043D\u0438\u043A\u0430
      (\u0412\u0435\u0440\u0445)\n\n- \u0412\u0435\u0441 -\n\n\u041E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F
      \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u044C \u0432\u044B\u0431\u043E\u0440\u0430
      \u044D\u0442\u043E\u0439 \u0440\u0435\u043B\u0438\u043A\u0432\u0438\u0438.\n\u0427\u0435\u043C
      \u0432\u044B\u0448\u0435 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435,
      \u0442\u0435\u043C \u0432\u044B\u0448\u0435 \u0448\u0430\u043D\u0441 \u0432\u044B\u0431\u043E\u0440\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 7903608832
    m_Localized: "\u0420\u0435\u043B\u0438\u043A\u0432\u0438\u044F \u0441\u043E\u044E\u0437\u043D\u0438\u043A\u0430
      (\u041D\u0438\u0437)\n\n- \u041A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E
      \u0432\u043B\u0430\u0434\u0435\u043D\u0438\u044F \u044E\u043D\u0438\u0442\u0430\u043C\u0438
      -\n\n\u041A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E \u044E\u043D\u0438\u0442\u043E\u0432,
      \u043A\u043E\u0442\u043E\u0440\u044B\u043C\u0438 \u0432\u044B \u0432 \u0434\u0430\u043D\u043D\u044B\u0439
      \u043C\u043E\u043C\u0435\u043D\u0442 \u0432\u043B\u0430\u0434\u0435\u0435\u0442\u0435
      \u0438 \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u043E\u0434\u0432\u0435\u0440\u0436\u0435\u043D\u044B
      \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044E \u044D\u0442\u043E\u0439 \u0440\u0435\u043B\u0438\u043A\u0432\u0438\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 9510027264
    m_Localized: "\u0420\u0435\u043B\u0438\u043A\u0432\u0438\u044F \u0432\u0440\u0430\u0433\u0430
      (\u0412\u0435\u0440\u0445)\n\n- \u041C\u043D\u043E\u0436\u0438\u0442\u0435\u043B\u044C
      \u0434\u0435\u0431\u0430\u0444\u0430 -\n\n\u0415\u0441\u043B\u0438 \u044D\u0442\u0430
      \u0440\u0435\u043B\u0438\u043A\u0432\u0438\u044F \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0430,
      \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u043A\u0438
      \u0446\u0435\u043B\u0435\u0432\u043E\u0439 \u0435\u0434\u0438\u043D\u0438\u0446\u044B
      \u0443\u043C\u0435\u043D\u044C\u0448\u0430\u044E\u0442\u0441\u044F \u043D\u0430
      \u044D\u0442\u043E\u0442 \u043A\u043E\u044D\u0444\u0444\u0438\u0446\u0438\u0435\u043D\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 155867552382976
    m_Localized: "[\u0411\u0435\u0437\u0443\u043C\u0438\u0435]\n\u0410\u0442\u0430\u043A\u0443\u0435\u0442
