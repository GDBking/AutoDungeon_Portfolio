  JASkillName: "\u7834\u7247\u5438\u53CE"
  JASkillDesc: "\u3053\u306E\u30E6\u30CB\u30C3\u30C8\u306B\u7834\u7247\u3092\u30C9\u30E9\u30C3\u30B0\u3057\u3066\u5F37\u5316\u3057\u3066\u304F\u3060\u3055\u3044\u3002\u3053\u308C\u306F\u30B9\u30AD\u30EB\u306E\u8AAC\u660E\u3067\u3059\u3002"
