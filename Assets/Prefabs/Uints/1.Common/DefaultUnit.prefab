  PT_BRSkillDesc: "Arraste um fragmento para esta unidade para aprimor\xE1-la. Esta
    \xE9 a descri\xE7\xE3o da habilidade."
  RUSkillName: "\u041F\u043E\u0433\u043B\u043E\u0449\u0435\u043D\u0438\u0435 \u043E\u0441\u043A\u043E\u043B\u043A\u0430"
  RUSkillDesc: "\u041F\u0435\u0440\u0435\u0442\u0430\u0449\u0438\u0442\u0435 \u043E\u0441\u043A\u043E\u043B\u043E\u043A
