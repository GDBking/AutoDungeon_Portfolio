  ZH_HANSItemName: "\u795E\u4E4B\u6069\u8D50"
  ZH_HANSDesc: "\u4ECE\u60A8\u6301\u6709\u7684\u5355\u4F4D\u788E\u7247\u4E2D\u968F\u673A\u590D\u5236\u4E00\u4E2A\u788E\u7247\u5E76\u5C06\u5176\u53EC\u5524\u5230\u6218\u573A\u4E0A\u3002"
