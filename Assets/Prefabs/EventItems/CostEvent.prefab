    \u0441\u0442\u043E\u0438\u043C\u043E\u0441\u0442\u0438, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u043C\u044B\u0445
    \u0442\u043E\u043B\u044C\u043A\u043E \u0432 \u044D\u0442\u043E\u043C \u0431\u043E\u044E,
    \u043E\u0442 10 \u0434\u043E 15."
  ZH_HANSItemName: "\u6D88\u8017\u788E\u7247"
  ZH_HANSDesc: "\u968F\u673A\u7ED9\u4E8810\u523015\u70B9\u4EC5\u80FD\u5728\u672C\u6B21\u6218\u6597\u4E2D\u4F7F\u7528\u7684\u6D88\u8017\u3002"
