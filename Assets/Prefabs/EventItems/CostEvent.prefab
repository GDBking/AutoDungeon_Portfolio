  ID: event_cost
  itemName: "\uCF54\uC2A4\uD2B8 \uC870\uAC01"
  desc: "\uD574\uB2F9 \uC804\uD22C\uC5D0\uC11C\uB9CC \uC0AC\uC6A9 \uAC00\uB2A5\uD55C
    \uCF54\uC2A4\uD2B8\uB97C 10~15\uAC1C \uC0AC\uC774\uC5D0\uC11C \uB79C\uB364\uD558\uAC8C
